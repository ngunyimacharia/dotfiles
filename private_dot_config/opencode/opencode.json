{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "./tmux-status.js",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "ray": {
      "type": "remote",
      "url": "http://127.0.0.1:2411/mcp",
      "enabled": true
    }
  },
  "theme": "everforest"
}
