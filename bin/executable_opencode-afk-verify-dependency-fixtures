#!/bin/sh

set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
script_path="$repo_root/bin/executable_opencode-afk"

if [ ! -x "$script_path" ]; then
  script_path="$repo_root/bin/opencode-afk"
fi

tmp_root=$(mktemp -d)
trap 'rm -rf "$tmp_root"' EXIT INT TERM HUP

temp_home="$tmp_root/home"
temp_bin_fzf="$tmp_root/bin-fzf"
temp_bin_menu="$tmp_root/bin-menu"
temp_fzf_root="$tmp_root/fzf-root"
temp_menu_root="$tmp_root/menu-root"

mkdir -p "$temp_home/.config/opencode/prompts" "$temp_bin_fzf" "$temp_bin_menu" "$temp_fzf_root/.scratch" "$temp_menu_root/.scratch"

cat > "$temp_home/.config/opencode/prompts/afk-prompt.md" <<'EOF'
Verification prompt
EOF

cat > "$temp_bin_fzf/opencode" <<'EOF'
#!/bin/sh

case "$1" in
  run)
    echo "[fake opencode] run $*" >&2
    exit 0
    ;;
  models)
    echo "fixture-model"
    exit 0
    ;;
esac

echo "[fake opencode] unsupported command: $*" >&2
exit 0
EOF

cat > "$temp_bin_fzf/fzf" <<'EOF'
#!/bin/sh

while [ $# -gt 0 ]; do
  shift
done

cat
EOF

cp "$temp_bin_fzf/opencode" "$temp_bin_menu/opencode"

chmod +x "$temp_bin_fzf/opencode" "$temp_bin_fzf/fzf" "$temp_bin_menu/opencode"

create_issue() {
  root="$1"
  relative_path="$2"
  status_line="$3"
  body="$4"

  issue_path="$root/$relative_path"
  mkdir -p "$(dirname "$issue_path")"
  {
    printf '# %s\n\n' "$(basename "$relative_path" .md)"
    printf '%s\n\n' "$status_line"
    printf '%s\n' "$body"
  } > "$issue_path"
}

populate_fixture_root() {
  root="$1"
  mkdir -p "$root/.scratch/dependency-aware-opencode-afk/issues"
  printf '.scratch/\n' > "$root/.gitignore"

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/01-no-deps.md" "Status: ready-for-agent" '## Summary

No dependencies fixture.'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/02-blocking-none.md" "Status: ready-for-agent" '## Summary

Blocking none fixture.

## Dependencies

Blocking:
- None'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/03-terminal-blocker.md" "Status: done" '## Summary

Terminal blocker fixture.'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/04-blocked-by-terminal.md" "Status: ready-for-agent" '## Summary

Blocked by terminal dependency.

## Dependencies

Blocking:
- `.scratch/dependency-aware-opencode-afk/issues/03-terminal-blocker.md`'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/05-non-terminal-blocker.md" "Status: ready-for-agent" '## Summary

Non-terminal blocker fixture.'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/06-blocked-by-non-terminal.md" "Status: ready-for-agent" '## Summary

Blocked by non-terminal dependency.

## Dependencies

Blocking:
- `.scratch/dependency-aware-opencode-afk/issues/05-non-terminal-blocker.md`'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/07-missing-blocker.md" "Status: ready-for-agent" '## Summary

Missing blocker fixture.

## Dependencies

Blocking:
- `.scratch/dependency-aware-opencode-afk/issues/99-missing-blocker.md`'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/08-related-only.md" "Status: ready-for-agent" '## Summary

Related-only fixture.

## Dependencies

Related:
- `.scratch/dependency-aware-opencode-afk/issues/03-terminal-blocker.md`'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/09-multiple-blockers.md" "Status: ready-for-agent" '## Summary

Multiple blockers fixture.

## Dependencies

Blocking:
- `.scratch/dependency-aware-opencode-afk/issues/03-terminal-blocker.md`
- `.scratch/dependency-aware-opencode-afk/issues/05-non-terminal-blocker.md`'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/10-upstream-ready.md" "Status: ready-for-agent" '## Summary

Upstream fixture.'

  create_issue "$root" ".scratch/dependency-aware-opencode-afk/issues/11-downstream-ready.md" "Status: ready-for-agent" '## Summary

Downstream fixture.

## Dependencies

Blocking:
- `.scratch/dependency-aware-opencode-afk/issues/10-upstream-ready.md`'
}

assert_contains() {
  needle="$1"
  file_path="$2"
  if ! awk -v needle="$needle" 'BEGIN { found = 0 } { if (index($0, needle) > 0) found = 1 } END { exit found ? 0 : 1 }' "$file_path"; then
    echo "[ERROR] missing expected output: $needle" >&2
    echo "[ERROR] in file: $file_path" >&2
    exit 1
  fi
}

assert_not_contains() {
  needle="$1"
  file_path="$2"
  if awk -v needle="$needle" 'BEGIN { found = 0 } { if (index($0, needle) > 0) found = 1 } END { exit found ? 0 : 1 }' "$file_path"; then
    echo "[ERROR] unexpected output: $needle" >&2
    echo "[ERROR] in file: $file_path" >&2
    exit 1
  fi
}

reduced_path_without_fzf() {
  original_path="$1"
  fzf_dir="$2"

  old_ifs=$IFS
  IFS=:
  set -- $original_path
  IFS=$old_ifs

  reduced_path=""
  for entry in "$@"; do
    [ -z "$entry" ] && continue
    [ "$entry" = "$fzf_dir" ] && continue
    if [ -z "$reduced_path" ]; then
      reduced_path="$entry"
    else
      reduced_path="$reduced_path:$entry"
    fi
  done

  printf '%s\n' "$reduced_path"
}

run_dependency_matrix() {
  flow_name="$1"
  root="$2"
  path_prefix="$3"
  expect_fzf="$4"

  populate_fixture_root "$root"

  output_one="$tmp_root/${flow_name}-run-1.log"
  output_two="$tmp_root/${flow_name}-run-2.log"

  menu_path="$temp_bin_menu"
  if [ -n "$reduced_path" ]; then
    menu_path="$temp_bin_menu:$reduced_path"
  fi

  if [ "$expect_fzf" = "yes" ]; then
    sh -n "$script_path"
    (
      cd "$root" && env PATH="$path_prefix" HOME="$temp_home" "$script_path" --model fixture-model
    ) > "$output_one" 2>&1
    assert_contains "dependency-aware-opencode-afk/04-blocked-by-terminal" "$output_one"
    assert_contains "dependency-aware-opencode-afk/11-downstream-ready" "$output_one"

    (
      cd "$root" && env PATH="$path_prefix" HOME="$temp_home" "$script_path" --model fixture-model
    ) > "$output_two" 2>&1
  else
    sh -n "$script_path"
    (
      cd "$root" && printf 'a\n' | env PATH="$menu_path" HOME="$temp_home" "$script_path" --model fixture-model
    ) > "$output_one" 2>&1
    assert_contains "dependency-aware-opencode-afk/01-no-deps" "$output_one"
    assert_contains "dependency-aware-opencode-afk/04-blocked-by-terminal" "$output_one"
  fi
}

if [ ! -f "$repo_root/bin/executable_opencode-afk" ] && [ ! -f "$repo_root/bin/opencode-afk" ]; then
  echo "[ERROR] opencode-afk script not found at $repo_root/bin/executable_opencode-afk" >&2
  exit 1
fi

fzf_path=$(command -v fzf 2>/dev/null || true)
fzf_dir=""
if [ -n "$fzf_path" ]; then
  fzf_dir=$(dirname "$fzf_path")
fi
reduced_path=$(reduced_path_without_fzf "$PATH" "$fzf_dir")

run_scratch_safety_tests() {
  scratch_tmp_root="$tmp_root/scratch-safety"
  mkdir -p "$scratch_tmp_root"

  echo "[INFO] Running .scratch safety validation tests..."

  # Test 1: Missing .scratch directory - should exit 0 with warning
  missing_scratch_root="$scratch_tmp_root/missing-scratch"
  mkdir -p "$missing_scratch_root"
  output="$tmp_root/missing-scratch.log"
  if (
    cd "$missing_scratch_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    assert_contains "No .scratch directory found" "$output"
  else
    echo "[ERROR] missing .scratch test should exit 0" >&2
    exit 1
  fi

  # Test 2: Ignored and untracked .scratch - should proceed to ticket scanning
  ignored_scratch_root="$scratch_tmp_root/ignored-scratch"
  mkdir -p "$ignored_scratch_root/.scratch/feature-a/issues"
  printf '.scratch/\n' > "$ignored_scratch_root/.gitignore"
  create_issue "$ignored_scratch_root" ".scratch/feature-a/issues/01-test.md" "Status: ready-for-agent" '## Summary

Ignored scratch test.'
  output="$tmp_root/ignored-scratch.log"
  if (
    cd "$ignored_scratch_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    assert_contains "Selected 1 AFK ticket(s):" "$output"
    assert_contains "feature-a/01-test" "$output"
  else
    echo "[ERROR] ignored .scratch test should exit 0" >&2
    exit 1
  fi

  # Test 3: Unignored .scratch - should fail with error
  unignored_scratch_root="$scratch_tmp_root/unignored-scratch"
  mkdir -p "$unignored_scratch_root/.scratch/feature-b/issues"
  printf '*.log\n' > "$unignored_scratch_root/.gitignore"
  output="$tmp_root/unignored-scratch.log"
  if (
    cd "$unignored_scratch_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    echo "[ERROR] unignored .scratch test should exit non-zero" >&2
    exit 1
  else
    assert_contains ".scratch is present but not ignored in .gitignore" "$output"
  fi

  # Test 4: No .gitignore at all - should fail with error
  no_gitignore_root="$scratch_tmp_root/no-gitignore"
  mkdir -p "$no_gitignore_root/.scratch/feature-c/issues"
  output="$tmp_root/no-gitignore.log"
  if (
    cd "$no_gitignore_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    echo "[ERROR] no .gitignore test should exit non-zero" >&2
    exit 1
  else
    assert_contains "no .gitignore found" "$output"
  fi

  # Test 5: Tracked .scratch/issues/... files - should fail with error
  tracked_issues_root="$scratch_tmp_root/tracked-issues"
  mkdir -p "$tracked_issues_root/.scratch/feature-d/issues"
  printf '.scratch/\n' > "$tracked_issues_root/.gitignore"
  touch "$tracked_issues_root/.scratch/feature-d/issues/.keep"
  output="$tmp_root/tracked-issues.log"
  git -C "$tracked_issues_root" init -q
  git -C "$tracked_issues_root" add -f .scratch/feature-d
  if (
    cd "$tracked_issues_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    echo "[ERROR] tracked .scratch/issues test should exit non-zero" >&2
    exit 1
  else
    assert_contains "contains tracked files" "$output"
    assert_contains ".scratch/feature-d" "$output"
  fi

  # Test 6: Tracked .scratch/.opencode-afk-logs/... - should fail with error
  tracked_logs_root="$scratch_tmp_root/tracked-logs"
  mkdir -p "$tracked_logs_root/.scratch/.opencode-afk-logs"
  printf '.scratch/\n' > "$tracked_logs_root/.gitignore"
  touch "$tracked_logs_root/.scratch/.opencode-afk-logs/.keep"
  output="$tmp_root/tracked-logs.log"
  git -C "$tracked_logs_root" init -q
  git -C "$tracked_logs_root" add -f .scratch/.opencode-afk-logs
  if (
    cd "$tracked_logs_root" && env PATH="$temp_bin_fzf:$PATH" HOME="$temp_home" "$script_path" --model fixture-model
  ) > "$output" 2>&1; then
    echo "[ERROR] tracked .scratch/.opencode-afk-logs test should exit non-zero" >&2
    exit 1
  else
    assert_contains "contains tracked files" "$output"
    assert_contains ".scratch/.opencode-afk-logs" "$output"
  fi

  echo "[INFO] .scratch safety validation tests passed."
}

run_dependency_matrix "fzf" "$temp_fzf_root" "$temp_bin_fzf:$PATH" "yes"
run_dependency_matrix "menu" "$temp_menu_root" "$temp_bin_menu:${reduced_path:-$PATH}" "no"

run_scratch_safety_tests

echo "Dependency fixture verification passed for fzf and fallback menu flows."
