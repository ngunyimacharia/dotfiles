#!/bin/sh

# opencode-afk: Automatically process AFK tickets using opencode
# Scans .scratch/*/issues/*.md, lets the user select eligible AFK tickets, and runs them
# Usage: opencode-afk [--model <model>] [--select-model]

set -e
set -m

# --- CLI Args ---
SELECT_MODEL=false
MODEL=""

while [ $# -gt 0 ]; do
  case "$1" in
    --model)
      if [ $# -lt 2 ] || [ -z "$2" ]; then
        echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') --model requires a value" >&2
        exit 1
      fi
      MODEL="$2"
      shift 2
      ;;
    --select-model)
      SELECT_MODEL=true
      shift
      ;;
    *)
      echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Unknown option: $1" >&2
      echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Usage: opencode-afk [--model <model>] [--select-model]" >&2
      exit 1
      ;;
  esac
done

# --- Model Selection ---
if [ -z "$MODEL" ] || [ "$SELECT_MODEL" = true ]; then
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Fetching available models..."
  model_list=$(opencode models 2>/dev/null)

  if [ -z "$model_list" ]; then
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Could not fetch model list from opencode. Is opencode configured?" >&2
    exit 1
  fi

  # Try fzf first
  if command -v fzf >/dev/null 2>&1; then
    MODEL=$(echo "$model_list" | fzf --prompt="Select model for AFK: " --height=20 --reverse)
  else
    # POSIX fallback: numbered menu
    models_tmp=$(mktemp)
    echo "$model_list" | awk '{ print NR ") " $0 }' > "$models_tmp"
    cat "$models_tmp"
    printf "\nEnter number: "
    read -r num
    MODEL=$(sed -n "${num}p" "$models_tmp" | sed 's/^[0-9]*) //')
    rm -f "$models_tmp"
  fi

  if [ -z "$MODEL" ]; then
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') No model selected. Exiting." >&2
    exit 1
  fi
fi

echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Using model: $MODEL"

# --- Config ---
PROMPT_FILE="${HOME}/.config/opencode/prompts/afk-prompt.md"
BASE_DIR="$(pwd)"
LOG_DIR="${BASE_DIR}/.scratch/.opencode-afk-logs"
SENTINEL_DIR="${LOG_DIR}/sentinels"
MAX_CONCURRENT=3

get_ticket_status() {
  ticket_file="$1"

  status_val=$(awk '/^##[[:space:]]+Status[[:space:]]*$/ {found=1; next} found && NF {print tolower($0); exit}' "$ticket_file")
  if [ -n "$status_val" ]; then
    printf '%s\n' "$status_val"
    return
  fi

  awk '
    {
      lower = tolower($0)
      if (lower ~ /^status:[[:space:]]*/) {
        sub(/^[Ss][Tt][Aa][Tt][Uu][Ss]:[[:space:]]*/, "", $0)
        print tolower($0)
        exit
      }
    }
  ' "$ticket_file"
}

is_terminal_status() {
  case "$1" in
    *done*|*closed*|*complete*|*resolved*) return 0 ;;
    *) return 1 ;;
  esac
}

is_ready_for_agent_status() {
  case "$1" in
    *ready-for-agent*) return 0 ;;
    *) return 1 ;;
  esac
}

has_afk_executor() {
  grep -q "Executor:[[:space:]]*\`\?AFK\`\?" "$1" 2>/dev/null
}

ticket_label() {
  ticket_file="$1"
  feature_slug=$(basename "$(dirname "$(dirname "$ticket_file")")")
  issue_name=$(basename "$ticket_file" .md)
  printf '%s\n' "$feature_slug/$issue_name"
}

select_tickets_with_fzf() {
  eligible_file="$1"
  display_file=$(mktemp)
  selection_file=$(mktemp)

  printf '__ALL__\t[Select all tickets]\n' > "$display_file"
  while read -r ticket; do
    [ -z "$ticket" ] && continue
    printf '%s\t%s\n' "$ticket" "$(ticket_label "$ticket")" >> "$display_file"
  done < "$eligible_file"

  if fzf --multi --prompt="Select tickets: " --height=20 --reverse --with-nth=2.. < "$display_file" > "$selection_file"; then
    :
  else
    rm -f "$display_file" "$selection_file"
    return 1
  fi

  if awk -F '\t' '$1 == "__ALL__" { found = 1 } END { exit found ? 0 : 1 }' "$selection_file"; then
    cat "$eligible_file"
  else
    awk -F '\t' 'NF { print $1 }' "$selection_file"
  fi

  rm -f "$display_file" "$selection_file"
}

select_tickets_with_menu() {
  eligible_file="$1"
  display_file=$(mktemp)
  selected_file=$(mktemp)
  ticket_count=0

  while read -r ticket; do
    [ -z "$ticket" ] && continue
    ticket_count=$((ticket_count + 1))
    label=$(ticket_label "$ticket")
    printf '%s\t%s\t%s\n' "$ticket_count" "$ticket" "$label" >> "$display_file"
    printf '%s) %s\n' "$ticket_count" "$label" >&2
  done < "$eligible_file"

  printf 'a) Select all\n' >&2
  printf '\nEnter selection(s): ' >&2
  read -r raw_selection

  selection=$(printf '%s\n' "$raw_selection" | tr ',' ' ')
  if [ -z "$selection" ]; then
    rm -f "$display_file" "$selected_file"
    return 1
  fi

  for choice in $selection; do
    lower_choice=$(printf '%s' "$choice" | tr '[:upper:]' '[:lower:]')
    if [ "$lower_choice" = "a" ] || [ "$lower_choice" = "all" ]; then
      cat "$eligible_file"
      rm -f "$display_file" "$selected_file"
      return 0
    fi

    case "$choice" in
      *[!0-9]*|'')
        echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Invalid selection: $choice" >&2
        rm -f "$display_file" "$selected_file"
        return 2
        ;;
    esac

    if [ "$choice" -lt 1 ] || [ "$choice" -gt "$ticket_count" ]; then
      echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Selection out of range: $choice" >&2
      rm -f "$display_file" "$selected_file"
      return 2
    fi

    awk -F '\t' -v selected="$choice" '$1 == selected { print $2 }' "$display_file" >> "$selected_file"
  done

  awk '!seen[$0]++' "$selected_file"
  rm -f "$display_file" "$selected_file"
}

rewrite_ticket_list() {
  source_file="$1"
  target_file="$2"
  tmpfile=$(mktemp)

  awk 'NF && !seen[$0]++ { print }' "$source_file" > "$tmpfile"
  if [ ! -s "$tmpfile" ]; then
    rm -f "$tmpfile"
    return 1
  fi

  mv "$tmpfile" "$target_file"
}

validate_scratch_safety() {
  gitignore_file="${BASE_DIR}/.gitignore"

  if [ ! -f "$gitignore_file" ]; then
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') .scratch is present but not ignored: no .gitignore found" >&2
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Add '.scratch/' to .gitignore before running opencode-afk" >&2
    return 1
  fi

  scratch_ignored=false
  while IFS= read -r line; do
    case "$line" in
      '#'*|'') continue ;;
    esac
    case "$line" in
      *'.scratch'*|*'.scratch/'*)
        scratch_ignored=true
        break
        ;;
    esac
  done < "$gitignore_file"

  if [ "$scratch_ignored" = false ]; then
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') .scratch is present but not ignored in .gitignore" >&2
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Add '.scratch/' to .gitignore before running opencode-afk" >&2
    return 1
  fi

  tracked_files=$(git -C "$BASE_DIR" ls-files '.scratch/**' 2>/dev/null || true)
  if [ -n "$tracked_files" ]; then
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') .scratch is ignored but contains tracked files:" >&2
    printf '%s\n' "$tracked_files" | while IFS= read -r tracked_file; do
      echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S')   - $tracked_file" >&2
    done
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Untrack .scratch files before running opencode-afk" >&2
    return 1
  fi

  return 0
}

# Check prompt file exists
if [ ! -f "$PROMPT_FILE" ]; then
  echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') Prompt file not found at $PROMPT_FILE" >&2
  exit 1
fi

# Check for .scratch directory
if [ ! -d ".scratch" ]; then
  echo "[WARN] $(date '+%Y-%m-%d %H:%M:%S') No .scratch directory found in current directory ($(pwd))"
  exit 0
fi

# Validate .scratch safety before proceeding
if ! validate_scratch_safety; then
  exit 1
fi

# Get recent commits for context
COMMITS=$(git log -n 5 --format="%H%n%ad%n%B---" --date=short 2>/dev/null || echo "No commits found")

# Create dirs
mkdir -p "$LOG_DIR"
rm -rf "$SENTINEL_DIR"
mkdir -p "$SENTINEL_DIR"

# --- Select pending AFK tickets ---
echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Scanning for AFK tickets..."
TICKET_LIST=$(mktemp)
find ".scratch" -path "*/issues/*.md" -type f 2>/dev/null | while read -r issue_file; do
  status_val=$(get_ticket_status "$issue_file")

  if is_terminal_status "$status_val"; then
    continue
  fi

  if is_ready_for_agent_status "$status_val" || has_afk_executor "$issue_file"; then
    # Convert to absolute path
    echo "${BASE_DIR}/${issue_file}"
  fi
done > "$TICKET_LIST"

if [ ! -s "$TICKET_LIST" ]; then
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') No pending AFK tickets found."
  rm -f "$TICKET_LIST"
  exit 0
fi

SELECTED_TICKETS=$(mktemp)
if command -v fzf >/dev/null 2>&1; then
  if select_tickets_with_fzf "$TICKET_LIST" > "$SELECTED_TICKETS"; then
    :
  else
    echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') No tickets selected. Exiting."
    rm -f "$TICKET_LIST" "$SELECTED_TICKETS"
    exit 0
  fi
else
  if select_tickets_with_menu "$TICKET_LIST" > "$SELECTED_TICKETS"; then
    :
  else
    menu_status=$?
    rm -f "$TICKET_LIST" "$SELECTED_TICKETS"
    if [ "$menu_status" -eq 2 ]; then
      exit 1
    fi
    echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') No tickets selected. Exiting."
    exit 0
  fi
fi

if ! rewrite_ticket_list "$SELECTED_TICKETS" "$TICKET_LIST"; then
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') No tickets selected. Exiting."
  rm -f "$TICKET_LIST" "$SELECTED_TICKETS"
  exit 0
fi
rm -f "$SELECTED_TICKETS"

TICKET_COUNT=$(awk 'NF { count++ } END { print count + 0 }' "$TICKET_LIST")
echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Selected $TICKET_COUNT AFK ticket(s):"
while read -r selected_ticket; do
  [ -z "$selected_ticket" ] && continue
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S')   - $(ticket_label "$selected_ticket")"
done < "$TICKET_LIST"
echo ""

# --- Detect tmux ---
IN_TMUX=false
if [ -n "$TMUX" ]; then
  IN_TMUX=true
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Tmux detected: launching tickets in new windows"
else
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') No tmux detected: launching tickets as background processes"
fi
echo ""

# --- Create helper script for tmux mode ---
HELPER="${SENTINEL_DIR}/_run-ticket.sh"
cat > "$HELPER" <<EOF
#!/bin/sh

meta_file="\$1"
. "\$meta_file"

log_line() {
  if [ "\${STREAM_OUTPUT:-0}" = "1" ]; then
    printf '%s\n' "\$1"
  else
    printf '%s\n' "\$1" >> "\$LOG"
  fi
}

mark_ticket_done() {
  tmpfile=\$(mktemp)

  if awk '
    tolower(\$0) ~ /^status:[[:space:]]*/ {
      print "Status: done"
      updated = 1
      next
    }
    { print }
    END { exit updated ? 0 : 1 }
  ' "\$TICKET" > "\$tmpfile"; then
    mv "\$tmpfile" "\$TICKET"
    return
  fi

  rm -f "\$tmpfile"
  tmpfile=\$(mktemp)
  awk '
    /^##[[:space:]]+Status[[:space:]]*$/ {
      print
      in_status = 1
      next
    }
    in_status && !status_written && NF == 0 {
      print
      next
    }
    in_status && !status_written {
      print "done"
      status_written = 1
      in_status = 0
      next
    }
    { print }
    END {
      if (in_status && !status_written) {
        print "done"
      }
    }
  ' "\$TICKET" > "\$tmpfile"
  mv "\$tmpfile" "\$TICKET"
}

mark_failed() {
  if [ ! -f "\$DONE" ] && [ ! -f "\$FAILED" ]; then
    touch "\$FAILED"
  fi
}

trap 'log_line "[WARN] \$(date '+"'"'%Y-%m-%d %H:%M:%S'"'"') Ticket interrupted"; mark_failed; exit 130' INT TERM

ticket_content=\$(cat "\$TICKET")
prompt=\$(cat "$PROMPT_FILE")
commits=\$(cat "\$COMMITS_FILE")
model="$MODEL"

full_prompt="You are working in AFK (Away From Keyboard) mode. Do not ask any questions. Do not stop for confirmation. Implement the ticket and commit your changes when done.

Previous commits for context:
\${commits}

---

Ticket file: \${TICKET}

\${ticket_content}

---

Predefined instructions:
\${prompt}

---

Please implement this ticket fully. Make all necessary code changes, run tests if applicable, and commit the result using conventional commit format. Do not ask for clarification. Do not pause for approval. Just execute."

log_line "[INFO] \$(date '+%Y-%m-%d %H:%M:%S') Starting ticket"

if [ "\${STREAM_OUTPUT:-0}" = "1" ]; then
  opencode run --interactive --model "\$model" "\$full_prompt"
else
  opencode run --interactive --model "\$model" "\$full_prompt" >> "\$LOG" 2>&1
fi

if [ "\$?" -eq 0 ]; then
  end_epoch=\$(date +%s)
  duration=\$(( end_epoch - START_EPOCH ))
  mark_ticket_done
  log_line "[INFO] \$(date '+%Y-%m-%d %H:%M:%S') Ticket completed successfully (duration: \$(( duration / 60 ))m \$(( duration % 60 ))s)"
  touch "\$DONE"
else
  end_epoch=\$(date +%s)
  duration=\$(( end_epoch - START_EPOCH ))
  log_line "[ERROR] \$(date '+%Y-%m-%d %H:%M:%S') Ticket failed (duration: \$(( duration / 60 ))m \$(( duration % 60 ))s)"
  touch "\$FAILED"
  exit 1
fi
EOF
chmod +x "$HELPER"

# Write commits to shared file
COMMITS_FILE="${SENTINEL_DIR}/commits.txt"
printf '%s' "$COMMITS" > "$COMMITS_FILE"



# --- Launch tickets ---
PIDS_FILE=$(mktemp)
TMUX_WINDOW_NUM=0

while read -r ticket <&3; do
  [ -z "$ticket" ] && continue

  feature_slug=$(basename "$(dirname "$(dirname "$ticket")")")
  issue_name=$(basename "$ticket" .md)
  log_file="${LOG_DIR}/${feature_slug}-${issue_name}.log"
  done_file="${SENTINEL_DIR}/${feature_slug}-${issue_name}.done"
  failed_file="${SENTINEL_DIR}/${feature_slug}-${issue_name}.failed"

  START_EPOCH=$(date +%s)
  echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Starting: $feature_slug/$issue_name"

  stream_output="0"
  if [ "$IN_TMUX" = true ]; then
    stream_output="1"
    TMUX_WINDOW_NUM=$((TMUX_WINDOW_NUM + 1))
  fi

  # Create meta file for this ticket
  meta_file="${SENTINEL_DIR}/${feature_slug}-${issue_name}.meta"
  cat > "$meta_file" << EOF
TICKET="$ticket"
LOG="$log_file"
DONE="$done_file"
FAILED="$failed_file"
COMMITS_FILE="$COMMITS_FILE"
START_EPOCH="$START_EPOCH"
START_TIME="$(date '+%Y-%m-%d %H:%M:%S')"
STREAM_OUTPUT="$stream_output"
IN_TMUX="$IN_TMUX"
TMUX_WINDOW_NUM="$TMUX_WINDOW_NUM"
EOF

  if [ "$IN_TMUX" = true ]; then
    window_name="afk:${TMUX_WINDOW_NUM}"
    pane_id=$(tmux new-window -P -F '#{pane_id}' -n "$window_name" sh "$HELPER" "$meta_file")
    tmux pipe-pane -o -t "$pane_id" "cat >> '$log_file'"
  else
    # Background mode with concurrency limit
    while [ "$(jobs -r | wc -l | tr -d ' ')" -ge "$MAX_CONCURRENT" ]; do
      sleep 1
    done

    nohup sh "$HELPER" "$meta_file" >/dev/null 2>&1 &
    echo $! >> "$PIDS_FILE"
  fi
done 3< "$TICKET_LIST"

echo ""
echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Launch complete. Exiting without waiting for ticket completion."
rm -f "$TICKET_LIST"
rm -f "$PIDS_FILE"

echo ""
echo "[$(date '+%Y-%m-%d %H:%M:%S')] AFK tickets launched."
